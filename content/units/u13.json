  "dialogues": [
    {
      "id": "u13.d1",
      "scene": "A small teahouse at the foot of the torii avenue, near closing. The owner has kept the kettle on just for you two, and now it's time to go.",
      "turns": [
        {
          "speaker": "npc",
          "jp": "おきゃくさま、おちゃの おかわりは いかがですか？",
          "romaji": "o-kyaku-sama, o-cha no okawari wa ikaga desu ka?",
          "en": "would you care for another tea, honoured guests?"
        },
        {
          "speaker": "you",
          "expect_item": "u01.kekkou",
          "mode": "pick",
          "stakes": "It's closing time and she's being kind. Decline gently."
        },
        {
          "speaker": "npc",
          "jp": "きょうは とおくから ようこそ。",
          "romaji": "kyō wa tōku kara yōkoso.",
          "en": "thank you for coming all this way today."
        },
        {
          "speaker": "you",
          "expect_item": "u13.sumimasen_arigato",
          "mode": "pick",
          "stakes": "She stayed open late for you. Thank her for the trouble, the Japanese way."
        },
        {
          "speaker": "npc",
          "jp": "いえいえ。たびは たのしいですか？",
          "romaji": "ie ie. tabi wa tanoshii desu ka?",
          "en": "not at all. are you enjoying the trip?"
        },
        {
          "speaker": "you",
          "expect_item": "u10.tanoshii",
          "mode": "pick",
          "stakes": "The torii at dusk, warm tea in your hands. Tell her honestly."
        },
        {
          "speaker": "npc",
          "jp": "よかった。どうぞ、おきをつけて。",
          "romaji": "yokatta. dōzo, o-ki o tsukete.",
          "en": "I'm glad. please take care on your way."
        },
        {
          "speaker": "you",
          "expect_item": "u13.mata_kimasu",
          "mode": "speak",
          "stakes": "You mean it — you'd cross the world for this cup again. Tell her you'll be back."
        },
        {
          "speaker": "npc",
          "jp": "おまちして おります。",
          "romaji": "o-machi shite orimasu.",
          "en": "we'll be waiting for you."
        },
        {
          "speaker": "you",
          "expect_item": "u13.shitsurei",
          "mode": "pick",
          "stakes": "Shoes on at the genkan, the door half open. Take your leave politely."
        }
      ]
    }
  ]
