  "dialogues": [
    {
      "id": "u10.d1",
      "scene": "A wooden footbath on the edge of the onsen town at dusk. Steam, lantern light, the river below. A friendly local eases in beside you.",
      "turns": [
        {
          "speaker": "npc",
          "jp": "こんばんは。いい おゆですね。",
          "romaji": "konbanwa. ii o-yu desu ne.",
          "en": "evening. lovely hot water, isn't it?"
        },
        {
          "speaker": "you",
          "expect_item": "u10.ii_ne",
          "mode": "pick",
          "stakes": "Your feet are in heaven. Agree warmly — it is lovely."
        },
        {
          "speaker": "npc",
          "jp": "どちらから いらしたんですか？",
          "romaji": "dochira kara irashitan desu ka?",
          "en": "where have you come from?"
        },
        {
          "speaker": "you",
          "expect_item": "u10.kara_kimashita",
          "mode": "speak",
          "stakes": "The friendly question. Tell them you're from Scotland."
        },
        {
          "speaker": "npc",
          "jp": "スコットランド！とおいですね。",
          "romaji": "Sukottorando! tōi desu ne.",
          "en": "Scotland — that's far!"
        },
        {
          "speaker": "you",
          "expect_item": "u10.tanoshii",
          "mode": "pick",
          "stakes": "Far, but worth it. Tell them you're having a wonderful time."
        },
        {
          "speaker": "npc",
          "jp": "うれしいです。しゃしん、とりましょうか？",
          "romaji": "ureshii desu. shashin, torimashō ka?",
          "en": "that makes me happy. shall I take your photo?"
        },
        {
          "speaker": "you",
          "expect_item": "u10.shashin",
          "mode": "pick",
          "stakes": "Yes! The two of you, the lanterns behind. Ask them to take it."
        },
        {
          "speaker": "npc",
          "jp": "はい、チーズ！いいですね。",
          "romaji": "hai, chīzu! ii desu ne.",
          "en": "say cheese! that's a good one."
        },
        {
          "speaker": "you",
          "expect_item": "u01.arigatogozaimasu",
          "mode": "speak",
          "stakes": "A stranger's small kindness. Thank them properly."
        }
      ]
    }
  ]
