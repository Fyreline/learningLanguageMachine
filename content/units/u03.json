  "dialogues": [
    {
      "id": "u03.d1",
      "scene": "A convenience kiosk just past arrivals. You want two bottles of water and a travel card, jet-lagged and fumbling for cash.",
      "turns": [
        { "speaker": "npc", "jp": "いらっしゃいませ。", "romaji": "irasshaimase.", "en": "welcome." },
        { "speaker": "you", "expect_item": "u02.wa_arimasuka", "mode": "pick", "stakes": "Ask if they have water before you dig through the fridge." },
        { "speaker": "npc", "jp": "はい、あちらに ありますよ。", "romaji": "hai, achira ni arimasu yo.", "en": "yes, they're just over there." },
        { "speaker": "you", "expect_item": "u03.futatsu", "mode": "pick", "stakes": "Two of you, two bottles. Ask for two." },
        { "speaker": "npc", "jp": "スイカも いりますか？", "romaji": "Suika mo irimasu ka?", "en": "do you also want a Suica card?" },
        { "speaker": "you", "expect_item": "u01.onegaishimasu", "mode": "pick", "stakes": "Yes — you'll need it for the trains. Accept it." },
        { "speaker": "npc", "jp": "ぜんぶで にせんえんです。", "romaji": "zenbu de nisen-en desu.", "en": "that's two thousand yen altogether." },
        { "speaker": "you", "expect_item": "u03.kado_de", "mode": "speak", "stakes": "You'd rather not break a note. Ask if card is OK." },
        { "speaker": "npc", "jp": "だいじょうぶです。レシートは いりますか？", "romaji": "daijōbu desu. reshīto wa irimasu ka?", "en": "that's fine. would you like a receipt?" },
        { "speaker": "you", "expect_item": "u01.kekkou", "mode": "pick", "stakes": "You don't need it. Decline politely." }
      ]
    }
  ]
}
