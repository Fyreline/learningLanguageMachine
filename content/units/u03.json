    { "id": "u03.ni", "jp": "に", "romaji": "ni", "en": "two", "tags": ["number", "trip_core"], "trip_core": true },
    { "id": "u03.san", "jp": "さん", "romaji": "san", "en": "three", "tags": ["number", "trip_core"], "trip_core": true },
    { "id": "u03.yon", "jp": "よん", "romaji": "yon", "en": "four", "note": "yon is safer than shi (which sounds like 'death'). Both exist.", "tags": ["number"] },
    { "id": "u03.go", "jp": "ご", "romaji": "go", "en": "five", "tags": ["number"] },
    { "id": "u03.roku", "jp": "ろく", "romaji": "roku", "en": "six", "tags": ["number"] },
    { "id": "u03.nana", "jp": "なな", "romaji": "nana", "en": "seven", "note": "nana is clearer than shichi over noise. Use it.", "tags": ["number"] },

    { "id": "u03.hachi", "jp": "はち", "romaji": "hachi", "en": "eight", "tags": ["number"] },
    { "id": "u03.kyuu", "jp": "きゅう", "romaji": "kyū", "en": "nine", "tags": ["number"] },
    { "id": "u03.juu", "jp": "じゅう", "romaji": "jū", "en": "ten", "note": "Eleven is just jū-ichi, twenty is ni-jū. The system is kind.", "tags": ["number", "trip_core"], "trip_core": true },
    { "id": "u03.hyaku", "jp": "ひゃく", "romaji": "hyaku", "en": "hundred", "note": "Prices live here: 100 to 900 covers most snacks.", "tags": ["number", "money", "trip_core"], "trip_core": true },
    { "id": "u03.sen", "jp": "せん", "romaji": "sen", "en": "thousand", "note": "A 1,000-yen note is your everyday cash.", "tags": ["number", "money", "trip_core"], "trip_core": true },
    { "id": "u03.man", "jp": "まん", "romaji": "man", "en": "ten thousand", "note": "10,000, not 1,000×10 in speech: ichi-man. Big-ticket unit.", "tags": ["number", "money"] },
    { "id": "u03.en", "jp": "えん", "romaji": "en", "en": "yen", "note": "Written 円 on prices and notes; said 'en'. 500-en is a coin.", "tags": ["money", "trip_core"], "trip_core": true },

    { "id": "u03.zero", "jp": "ゼロ", "romaji": "zero", "en": "zero", "note": "Also rei; zero is fine and clear for phone numbers and prices.", "tags": ["number"] },
    { "id": "u03.gohyaku", "jp": "ごひゃく", "romaji": "gohyaku", "en": "five hundred", "note": "Regular. It's 300 and 600 and 800 that go irregular.", "tags": ["number", "money"] },
    { "id": "u03.sanbyaku", "jp": "さんびゃく", "romaji": "sanbyaku", "en": "three hundred", "note": "hyaku softens to byaku after san. Your ear will learn it.", "tags": ["number", "money"] },
    { "id": "u03.nisen", "jp": "にせん", "romaji": "nisen", "en": "two thousand", "note": "Sen stays regular for most: nisen, sanzen (that one shifts).", "tags": ["number", "money"] },
    { "id": "u03.ichiman", "jp": "いちまん", "romaji": "ichiman", "en": "ten thousand (¥10,000)", "note": "The big note. Breaking one at a konbini is completely normal.", "tags": ["number", "money"] },

    { "id": "u03.hitotsu", "jp": "ひとつ", "romaji": "hitotsu", "en": "one (thing)", "note": "The -tsu counter for general objects. Point and say 'hitotsu'.", "tags": ["number", "trip_core"], "trip_core": true },
    { "id": "u03.futatsu", "jp": "ふたつ", "romaji": "futatsu", "en": "two (things)", "note": "hitotsu, futatsu, mittsu... this set only goes to ten and it's gold.", "tags": ["number", "trip_core"], "trip_core": true },
    { "id": "u03.mittsu", "jp": "みっつ", "romaji": "mittsu", "en": "three (things)", "tags": ["number"] },
    { "id": "u03.ichimai", "jp": "いちまい", "romaji": "ichimai", "en": "one (ticket / flat thing)", "note": "-mai counts flat things: tickets, tissues, cards.", "tags": ["number"] },
    { "id": "u03.nimai", "jp": "にまい", "romaji": "nimai", "en": "two (tickets)", "note": "Two of you, two tickets: 'nimai kudasai'.", "tags": ["number", "trip_core"], "trip_core": true },

    { "id": "u03.kado", "jp": "カード", "romaji": "kādo", "en": "(credit) card", "tags": ["money"] },
    { "id": "u03.kado_de", "jp": "カードで いいですか", "romaji": "kādo de ii desu ka", "en": "is card OK?", "note": "Ask before you assume — many small places are cash-only.", "tags": ["money", "question", "trip_core"], "trip_core": true },
    { "id": "u03.genkin", "jp": "げんきん", "romaji": "genkin", "en": "cash", "note": "Japan still loves it. Carry some; ATMs at konbini are reliable.", "tags": ["money", "trip_core"], "trip_core": true },
    { "id": "u03.reshiito", "jp": "レシート", "romaji": "reshīto", "en": "receipt", "note": "'reshīto onegaishimasu' if you want one for tax-free later.", "tags": ["money", "shopping"] },
    { "id": "u03.suika", "jp": "スイカ", "romaji": "Suika", "en": "Suica (IC travel card)", "note": "Tap-to-pay for trains and konbini. Pasmo and ICOCA work the same.", "tags": ["money", "transport"] },
    { "id": "u03.otsuri", "jp": "おつり", "romaji": "otsuri", "en": "change (money back)", "note": "Handed on a small tray — take it from the tray, not the hand.", "tags": ["money", "culture"] }
  ],
