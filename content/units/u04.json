  "dialogues": [
    {
      "id": "u04.d1",
      "scene": "A loud, warm izakaya at 8pm. Steam, laughter, a chalkboard menu. The two of you slide up to the counter and the chef looks over.",
      "turns": [
        { "speaker": "npc", "jp": "いらっしゃい！なんめいさまですか？", "romaji": "irasshai! nanmei-sama desu ka?", "en": "welcome! how many are you?" },
        { "speaker": "you", "expect_item": "u04.futari_desu", "mode": "pick", "stakes": "Just the two of you. Answer so he can seat you." },
        { "speaker": "npc", "jp": "どうぞ、カウンターへ。おのみものは？", "romaji": "dōzo, kauntā e. o-nomimono wa?", "en": "please, take the counter. drinks?" },
        { "speaker": "you", "expect_item": "u04.biru_nihai", "mode": "speak", "stakes": "Kick the night off right. Order two beers." },
        { "speaker": "npc", "jp": "はい、なまビール にはい！", "romaji": "hai, nama-bīru nihai!", "en": "two draught beers coming up!" },
        { "speaker": "you", "expect_item": "u04.osusume_wa", "mode": "pick", "stakes": "You don't know the menu. Ask what he recommends." },
        { "speaker": "npc", "jp": "きょうは さばが おすすめですよ。", "romaji": "kyō wa saba ga osusume desu yo.", "en": "the mackerel's great today." },
        { "speaker": "you", "expect_item": "u04.arerugi_ga", "mode": "pick", "stakes": "One of you can't risk it. Warn him about the egg allergy before ordering." },
        { "speaker": "npc", "jp": "だいじょうぶ、たまごは つかいません。", "romaji": "daijōbu, tamago wa tsukaimasen.", "en": "no problem, no egg in it." },
        { "speaker": "you", "expect_item": "u04.kore_futatsu", "mode": "speak", "stakes": "Relieved. Order two of the mackerel." },
        { "speaker": "npc", "jp": "ありがとうございます！", "romaji": "arigatō gozaimasu!", "en": "thank you!" },
        { "speaker": "you", "expect_item": "u04.kanpai", "mode": "pick", "stakes": "The beers land. Glasses up — start the night." }
      ]
    }
  ]
}
