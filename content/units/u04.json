    { "id": "u04.l3", "title": "This one, twice", "kind": "teach", "new_items": ["u04.kore_hitotsu", "u04.kore_futatsu", "u04.biru", "u04.biru_nihai", "u04.osake", "u04.kanpai", "u04.toriaezu"] },
    { "id": "u04.l4", "title": "Delicious! and dietary needs", "kind": "teach", "new_items": ["u04.oishii", "u04.niku", "u04.sakana", "u04.niku_nashi", "u04.sakana_nashi", "u04.arerugi", "u04.arerugi_ga"] },
