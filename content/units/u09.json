  ],
  "dialogues": [
    {
      "id": "u09.d1",
      "scene": "A tiny ramen counter you've walked twenty minutes to reach. The shutter is half down, but a light's on inside. You call through the doorway.",
      "turns": [
        { "speaker": "npc", "jp": "はい、いらっしゃい。", "romaji": "hai, irasshai.", "en": "yes, come in." },
        { "speaker": "you", "expect_item": "u09.aitemasu", "mode": "speak", "stakes": "The shutter's half down. Check you're not too late — are they open?" },
        { "speaker": "npc", "jp": "あいてますよ。でも ラストオーダーは くじです。", "romaji": "aitemasu yo. demo rasuto-ōdā wa ku-ji desu.", "en": "we're open. but last orders are at nine." },
        { "speaker": "you", "expect_item": "u09.nanji", "mode": "pick", "stakes": "You've lost track of time. Ask what time it is now." },
        { "speaker": "npc", "jp": "いま はちじはんです。まだ だいじょうぶ。", "romaji": "ima hachi-ji han desu. mada daijōbu.", "en": "it's half eight. still fine." },
        { "speaker": "you", "expect_item": "u01.daijobu", "mode": "pick", "stakes": "Relief. Reassure him you're good — plenty of time." },
        { "speaker": "npc", "jp": "あしたも やってますよ。", "romaji": "ashita mo yattemasu yo.", "en": "we're open tomorrow too, by the way." },
        { "speaker": "you", "expect_item": "u09.ashita", "mode": "pick", "stakes": "You might come back. Repeat 'tomorrow' to check you heard right." },
        { "speaker": "npc", "jp": "ぜひ どうぞ。すわって ください。", "romaji": "zehi dōzo. suwatte kudasai.", "en": "please do. take a seat." },
        { "speaker": "you", "expect_item": "u01.arigatogozaimasu", "mode": "pick", "stakes": "You made it. Thank him and sit down to the good stuff." }
      ]
    }
  ]
}
