  "dialogues": [
    {
      "id": "u11.d1",
      "scene": "A koban on a corner, late afternoon. You've just realised your passport isn't in your bag. The officer sets down his tea and looks up, calm and kind.",
      "turns": [
        {
          "speaker": "npc",
          "jp": "こんにちは。どうしましたか？",
          "romaji": "konnichiwa. dō shimashita ka?",
          "en": "hello. what's happened?"
        },
        {
          "speaker": "you",
          "expect_item": "u11.tasukete_kudasai",
          "mode": "pick",
          "stakes": "Heart pounding. Ask him to help you."
        },
        {
          "speaker": "npc",
          "jp": "おちついて。なにが ありましたか？",
          "romaji": "ochitsuite. nani ga arimashita ka?",
          "en": "take a breath. what's the matter?"
        },
        {
          "speaker": "you",
          "expect_item": "u11.nakushimashita",
          "mode": "speak",
          "stakes": "Say the hard thing plainly — you've lost your passport."
        },
        {
          "speaker": "npc",
          "jp": "どこで なくしましたか？",
          "romaji": "doko de nakushimashita ka?",
          "en": "where did you lose it?"
        },
        {
          "speaker": "you",
          "expect_item": "u01.wakarimasen",
          "mode": "pick",
          "stakes": "You genuinely have no idea. Admit you don't know."
        },
        {
          "speaker": "npc",
          "jp": "だいじょうぶ。ホテルの ばんごうを おしえて ください。",
          "romaji": "daijōbu. hoteru no bangō o oshiete kudasai.",
          "en": "it's all right. give me your hotel's number."
        },
        {
          "speaker": "you",
          "expect_item": "u01.moichido",
          "mode": "pick",
          "stakes": "He spoke quickly and you're rattled. Ask him to say it once more."
        },
        {
          "speaker": "npc",
          "jp": "おとしものは よく もどりますよ。しんぱい ないです。",
          "romaji": "otoshimono wa yoku modorimasu yo. shinpai nai desu.",
          "en": "lost things usually turn up here. don't worry."
        },
        {
          "speaker": "you",
          "expect_item": "u01.arigatogozaimasu",
          "mode": "speak",
          "stakes": "The first steady breath in an hour. Thank him."
        }
      ]
    }
  ]
