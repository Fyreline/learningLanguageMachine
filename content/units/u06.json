  ],
  "dialogues": [
    {
      "id": "u06.d1",
      "scene": "A quiet backstreet after dark. Your phone's dead, you can't find the hotel, and there's a lit koban on the corner. The officer looks up.",
      "turns": [
        { "speaker": "npc", "jp": "こんばんは。どうしましたか？", "romaji": "konbanwa. dō shimashita ka?", "en": "good evening. what's the matter?" },
        { "speaker": "you", "expect_item": "u06.wa_doko", "mode": "speak", "stakes": "You need the hotel. Ask where it is. (Say your place in the slot.)" },
        { "speaker": "npc", "jp": "ああ、あの ホテルですね。", "romaji": "ā, ano hoteru desu ne.", "en": "ah, that hotel — I know it." },
        { "speaker": "you", "expect_item": "u06.chikaku", "mode": "pick", "stakes": "You're exhausted. Check hopefully — is it near?" },
        { "speaker": "npc", "jp": "はい、ちかいですよ。この みちを まっすぐです。", "romaji": "hai, chikai desu yo. kono michi o massugu desu.", "en": "yes, quite close. straight down this street." },
        { "speaker": "you", "expect_item": "u06.migi", "mode": "pick", "stakes": "You saw a fork ahead. Ask to confirm the turn — right?" },
        { "speaker": "npc", "jp": "いいえ、ひだりに まがって ください。", "romaji": "iie, hidari ni magatte kudasai.", "en": "no — turn left there." },
        { "speaker": "you", "expect_item": "u01.wakarimashita", "mode": "pick", "stakes": "Got it now. Let him know you've understood." },
        { "speaker": "npc", "jp": "きを つけて。", "romaji": "ki o tsukete.", "en": "take care." },
        { "speaker": "you", "expect_item": "u01.arigatogozaimasu", "mode": "speak", "stakes": "He rescued your night. Thank him properly." }
      ]
    }
  ]
}
