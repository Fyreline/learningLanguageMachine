  "dialogues": [
    {
      "id": "u12.d1",
      "scene": "Nishiki Market, Kyoto, mid-morning. A stall of golden skewers with no labels. The stallholder catches you looking and grins.",
      "turns": [
        {
          "speaker": "npc",
          "jp": "いらっしゃい！やきたてですよ。",
          "romaji": "irasshai! yakitate desu yo.",
          "en": "come on in! fresh off the grill."
        },
        {
          "speaker": "you",
          "expect_item": "u12.nan_no_niku",
          "mode": "speak",
          "stakes": "No labels anywhere. Point at the skewer and ask what meat it is."
        },
        {
          "speaker": "npc",
          "jp": "とりにくです。すこし からいですよ。",
          "romaji": "toriniku desu. sukoshi karai desu yo.",
          "en": "chicken. it's a little spicy, mind."
        },
        {
          "speaker": "you",
          "expect_item": "u12.haitte_imasu",
          "mode": "pick",
          "stakes": "The glaze looks eggy and one of you can't risk it. Ask if egg's in it."
        },
        {
          "speaker": "npc",
          "jp": "いいえ、たまごは つかって いません。",
          "romaji": "iie, tamago wa tsukatte imasen.",
          "en": "no, there's no egg in it."
        },
        {
          "speaker": "you",
          "expect_item": "u04.kore_futatsu",
          "mode": "pick",
          "stakes": "Safe, spicy, perfect. Order two of them."
        },
        {
          "speaker": "npc",
          "jp": "はい、どうぞ。あじは どうですか？",
          "romaji": "hai, dōzo. aji wa dō desu ka?",
          "en": "here you go. how's the taste?"
        },
        {
          "speaker": "you",
          "expect_item": "u12.karai",
          "mode": "pick",
          "stakes": "He wasn't joking about the heat. Tell him, eyes watering, that it's spicy."
        },
        {
          "speaker": "npc",
          "jp": "ははは！でも おいしいでしょう？",
          "romaji": "hahaha! demo oishii deshō?",
          "en": "haha! but it's good, right?"
        },
        {
          "speaker": "you",
          "expect_item": "u04.oishii",
          "mode": "speak",
          "stakes": "It really is. Tell him it's delicious."
        }
      ]
    }
  ]
