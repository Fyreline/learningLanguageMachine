# Copy this file to `.env`.
MICHI_ENVIRONMENT=development

# Auth (docs/AUTH.md) — 32+ random bytes, e.g. `openssl rand -hex 32`.
# Independent of Mishka Hub's own MISHKA_JWT_SECRET; rotating this logs out
# every Michi session but never touches Mishka Hub's.
MICHI_JWT_SECRET=

# Where Michi verifies logins (docs/AUTH.md §2). Must be loopback or https.
MICHI_MISHKA_BASE_URL=http://127.0.0.1:8000

# Optional overrides (defaults shown):
# MICHI_CORS_ORIGINS=["http://localhost:5174","http://127.0.0.1:5174","https://fyreline.github.io"]
# MICHI_DATABASE_URL=sqlite:////absolute/path/to/data/michi.db
# MICHI_ACCESS_TOKEN_TTL_MINUTES=15
# MICHI_REFRESH_TOKEN_TTL_DAYS=30
